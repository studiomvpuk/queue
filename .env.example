# =============================================================
# QueueEase Backend — environment variables
# Copy to .env and fill in. Never commit .env.
# =============================================================

NODE_ENV=development
PORT=3333
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,https://admin.queueease.ng,https://app.queueease.ng

# --- Database ---
DATABASE_URL=postgresql://queueease:queueease@localhost:5432/queueease?schema=public

# --- Redis (cache, BullMQ, Socket.io adapter) ---
REDIS_URL=redis://localhost:6379

# --- JWT auth ---
# Generate strong secrets with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=900                # 15 minutes
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=2592000           # 30 days

# --- OTP ---
OTP_LENGTH=6
OTP_TTL_SECONDS=300               # 5 minutes
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=QueueEase <noreply@queueease.com>

# --- SMS (Termii primary, Twilio fallback) ---
TERMII_API_KEY=
TERMII_SENDER_ID=QueueEase
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_DAILY_CAP=5                   # PRD §2.4 per-user daily ceiling

# --- Push (Expo) ---
EXPO_ACCESS_TOKEN=

# --- Payments (Phase 3) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info

# --- Rate limits (global defaults, per-route overrides via decorator) ---
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# --- Phase 3 ---
DAILY_API_KEY=                    # Daily.co for virtual queue calls
USSD_ENABLED=false                # feature-flag the USSD webhook route
